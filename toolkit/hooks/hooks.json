{
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/notify.sh 'Claude: Permission request' ${CLAUDE_PLUGIN_ROOT}/data/notification.ogg"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/notify.sh 'Claude: Ready' ${CLAUDE_PLUGIN_ROOT}/data/notification.ogg"
          }
        ]
      }
    ]
  }
}