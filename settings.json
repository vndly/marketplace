{
  "permissions": {
    "allow": [
      "Bash",
      "BashOutput",
      "Read",
      "Edit",
      "MultiEdit",
      "Write",
      "Glob",
      "Grep",
      "LS",
      "WebFetch",
      "WebSearch",
      "Skill",
      "Task",
      "Agent",
      "LSP",
      "mcp__ide__getDiagnostics"
    ]
  },
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/notify.sh 'Claude: Permission request' ~/.claude/data/notification.ogg"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/notify.sh 'Claude: Ready' ~/.claude/data/notification.ogg"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/scripts/statusline.sh",
    "padding": 0
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Working"
    ]
  },
  "effortLevel": "high",
  "voiceEnabled": true,
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  }
}
